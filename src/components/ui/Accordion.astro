---
/**
 * Accordion Component
 * Native HTML accordion with smooth animations
 */

interface Props {
  title: string;
  isOpen?: boolean;
  backgroundImage?: string;
}

const { title, isOpen = false, backgroundImage } = Astro.props;
---

<details
  class="accordion rounded-lg shadow-lg overflow-hidden bg-white"
  open={isOpen}
>
  <summary
    class={`accordion-header cursor-pointer py-6 px-6 transition-colors flex justify-between items-center ${backgroundImage ? 'bg-cover bg-center has-bg-image' : 'hover:bg-gray-50 no-bg-image'}`}
    style={backgroundImage ? `background-image: linear-gradient(rgba(255,255,255,0.6), rgba(255,255,255,0.6)), url(${backgroundImage});` : ''}
  >
    <h3 class={`text-lg font-semibold ${backgroundImage ? 'text-gray-800' : 'text-gray-900'}`}>{title}</h3>
    <svg
      class={`accordion-icon w-5 h-5 transition-transform duration-200 ${backgroundImage ? 'text-gray-800' : 'text-gray-500'}`}
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>
  <div class="accordion-content px-6 pb-4 bg-white text-gray-700">
    <div class="prose prose-sm max-w-none">
      <slot />
    </div>
  </div>
</details>

<style>
  /* Rotate icon when open */
  details[open] .accordion-icon {
    transform: rotate(180deg);
  }

  /* Gray background when open and no background image */
  details[open] .no-bg-image {
    background-color: #f3f4f6;
  }

  /* Remove default marker */
  summary::-webkit-details-marker,
  summary::marker {
    display: none;
  }

  /* Smooth animation for content */
  .accordion-content {
    animation: slideDown 0.3s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Focus styles for accessibility - only show on keyboard navigation */
  summary:focus-visible {
    outline: 1px solid #e5e7eb;
    outline-offset: 0;
  }
</style>
