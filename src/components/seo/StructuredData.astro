---
/**
 * Structured Data (Schema.org JSON-LD) Component
 * Critical for SEO and rich search results
 * Data is loaded from CMS (src/data/site.json)
 */
import siteData from '../../data/site.json';

const siteUrl = Astro.site?.toString() || 'https://inercia.com';
const { title, description, email, whatsapp, social, seo } = siteData;

// Build social media URLs array
const sameAs = [
  social?.facebook,
  social?.instagram
].filter(Boolean);

// MusicGroup Schema - Core organizational schema
const musicGroupSchema = {
  "@context": "https://schema.org",
  "@type": "MusicGroup",
  "@id": `${siteUrl}/#musicgroup`,
  "name": title,
  "genre": seo?.genres || ["Live Music", "Wedding Music", "Event Entertainment"],
  "url": siteUrl,
  "description": description,
  "sameAs": sameAs.length > 0 ? sameAs : undefined,
  "areaServed": {
    "@type": "Country",
    "name": seo?.areaServed || "España"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": `+${whatsapp}`,
    "contactType": "bookings",
    "email": email
  }
};

// LocalBusiness Schema - For local SEO
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${siteUrl}/#business`,
  "name": title,
  "image": `${siteUrl}/og-image.jpg`,
  "url": siteUrl,
  "telephone": `+${whatsapp}`,
  "email": email,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": seo?.city || "Madrid",
    "addressCountry": seo?.country || "ES"
  },
  "areaServed": {
    "@type": "Country",
    "name": seo?.areaServed || "España"
  }
};

// Remove undefined values from objects
function cleanSchema(obj: any): any {
  if (Array.isArray(obj)) {
    return obj.map(cleanSchema).filter(v => v !== undefined);
  }
  if (obj && typeof obj === 'object') {
    return Object.fromEntries(
      Object.entries(obj)
        .filter(([_, v]) => v !== undefined)
        .map(([k, v]) => [k, cleanSchema(v)])
    );
  }
  return obj;
}

const schemas = [
  cleanSchema(musicGroupSchema),
  cleanSchema(localBusinessSchema)
];
---

<!-- Schema.org JSON-LD Structured Data -->
{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
