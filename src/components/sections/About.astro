---
/**
 * About Section
 * Introduction paragraph about the music group
 */
import type { Language } from '../../i18n/utils';

interface Props {
  lang?: Language;
}

const { lang = 'es' } = Astro.props;

// Load about data from CMS
const aboutData = await import(`../../data/about/${lang}.json`);
const { title, content } = aboutData.default;
---

<section id="about" class="section-padding bg-white">
  <div class="container-custom">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
        {title}
      </h2>
      <div class="prose prose-lg mx-auto text-gray-700">
        {content.split('\n\n').map((paragraph: string) => (
          <p class="mb-4">{paragraph.trim()}</p>
        ))}
      </div>
    </div>
  </div>
</section>
