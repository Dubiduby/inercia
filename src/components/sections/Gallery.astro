---
/**
 * Gallery Section
 * Responsive image grid with lazy loading and optimization
 */
import { Image } from 'astro:assets';
import { useTranslations, type Language } from '../../i18n/utils';

interface Props {
  lang?: Language;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

// Load gallery images from CMS (dynamically load all JSON files)
const galleryModules = import.meta.glob('../../data/gallery/*.json', { eager: true });
const galleryFiles = Object.values(galleryModules);
const galleryImages = galleryFiles.length > 0
  ? galleryFiles
      .map((file: any) => file.default)
      .sort((a: any, b: any) => a.order - b.order)
      .map((item: any) => ({
        src: item.image,
        alt: item.alt,
        caption: item.caption || ''
      }))
  : // Fallback to placeholder data if no CMS data exists
    lang === 'es' ? [
      {
        src: '/images/gallery/placeholder-1.jpg',
        alt: 'Inercia tocando en una ceremonia de boda elegante',
        caption: 'Ceremonia de Boda'
      },
      {
        src: '/images/gallery/placeholder-2.jpg',
        alt: 'Banda en vivo tocando en evento corporativo',
        caption: 'Evento Corporativo'
      },
      {
        src: '/images/gallery/placeholder-3.jpg',
        alt: 'Músicos de Inercia tocando en recepción al aire libre',
        caption: 'Recepción al Aire Libre'
      },
      {
        src: '/images/gallery/placeholder-4.jpg',
        alt: 'Cuarteto de cuerdas en fiesta privada íntima',
        caption: 'Fiesta Privada'
      },
      {
        src: '/images/gallery/placeholder-5.jpg',
        alt: 'Banda tocando en escenario en celebración',
        caption: 'Celebración Especial'
      },
      {
        src: '/images/gallery/placeholder-6.jpg',
        alt: 'Ensamble de Inercia en el lugar',
        caption: 'Configuración Profesional'
      }
    ] : [
      {
        src: '/images/gallery/placeholder-1.jpg',
        alt: 'Inercia performing at an elegant wedding ceremony',
        caption: 'Wedding Ceremony Performance'
      },
      {
        src: '/images/gallery/placeholder-2.jpg',
        alt: 'Live band performing at corporate event',
        caption: 'Corporate Event Entertainment'
      },
      {
        src: '/images/gallery/placeholder-3.jpg',
        alt: 'Inercia musicians playing at outdoor reception',
        caption: 'Outdoor Reception'
      },
      {
        src: '/images/gallery/placeholder-4.jpg',
        alt: 'String quartet at intimate private party',
        caption: 'Private Party'
      },
      {
        src: '/images/gallery/placeholder-5.jpg',
        alt: 'Band performing on stage at celebration',
        caption: 'Special Celebration'
      },
      {
        src: '/images/gallery/placeholder-6.jpg',
        alt: 'Inercia ensemble at venue',
        caption: 'Professional Setup'
      }
    ];
---

<section id="gallery" class="section-padding bg-white">
  <div class="container-custom">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        {t('gallery.title')}
      </h2>
      <p class="text-xl text-gray-600">
        {lang === 'es'
          ? 'Momentos de nuestras actuaciones'
          : 'Moments from our performances'
        }
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {galleryImages.map((image, index) => (
        <div class="relative group overflow-hidden rounded-lg shadow-md hover:shadow-xl transition-shadow duration-300 aspect-square">
          <img
            src={image.src}
            alt={image.alt}
            loading={index < 4 ? 'eager' : 'lazy'}
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
            width="600"
            height="600"
          />
          {/* Overlay with caption on hover */}
          <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <p class="text-white text-center px-4 font-medium">
              {image.caption}
            </p>
          </div>
        </div>
      ))}
    </div>

    {galleryFiles.length === 0 && (
      <div class="text-center mt-8">
        <p class="text-gray-600 italic">
          {lang === 'es'
            ? '* Reemplazar imágenes placeholder con tus fotos reales de eventos'
            : '* Replace placeholder images with your actual event photos'
          }
        </p>
      </div>
    )}
  </div>
</section>

<style>
  /* Ensure consistent aspect ratios */
  .aspect-square {
    aspect-ratio: 1 / 1;
  }
</style>
