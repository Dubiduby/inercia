---
/**
 * Contact Section
 * Simple contact section with email and WhatsApp links
 */
import Button from '../ui/Button.astro';
import type { Language } from '../../i18n/utils';

interface Props {
  lang?: Language;
}

const { lang = 'es' } = Astro.props;

// Load contact information from site settings
const siteData = await import('../../data/site.json');
const { email, whatsapp } = siteData.default;

const whatsappMessage = lang === 'es'
  ? '¡Hola Inercia! Me gustaría consultar sobre sus servicios.'
  : 'Hello Inercia! I would like to inquire about your services.';
---

<section id="contact" class="section-padding bg-gradient-to-br from-accent to-blue-800 text-white">
  <div class="container-custom">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        {lang === 'es'
          ? 'Creemos Algo Increíble Juntos'
          : 'Let\'s Create Something Amazing Together'
        }
      </h2>
      <p class="text-xl mb-12 opacity-90">
        {lang === 'es'
          ? '¿Listo para hacer tu evento inolvidable? Contáctanos hoy.'
          : 'Ready to make your event unforgettable? Get in touch with us today.'
        }
      </p>

      <div class="grid md:grid-cols-2 gap-8 max-w-2xl mx-auto">
        <!-- Email Contact -->
        <div class="bg-white/10 backdrop-blur-sm rounded-lg p-8 hover:bg-white/20 transition-all duration-300">
          <svg class="w-12 h-12 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <h3 class="text-xl font-semibold mb-2">
            {lang === 'es' ? 'Envíanos un Email' : 'Email Us'}
          </h3>
          <p class="mb-4 opacity-90">
            {lang === 'es' ? 'Envíanos un mensaje cuando quieras' : 'Send us a message anytime'}
          </p>
          <Button
            href={`mailto:${email}`}
            variant="primary"
            class="bg-white text-accent hover:bg-gray-100"
          >
            {email}
          </Button>
        </div>

        <!-- WhatsApp Contact -->
        <div class="bg-white/10 backdrop-blur-sm rounded-lg p-8 hover:bg-white/20 transition-all duration-300">
          <svg class="w-12 h-12 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <h3 class="text-xl font-semibold mb-2">WhatsApp</h3>
          <p class="mb-4 opacity-90">
            {lang === 'es' ? 'Chatea con nosotros al instante' : 'Chat with us instantly'}
          </p>
          <Button
            href={`https://wa.me/${whatsapp}?text=${encodeURIComponent(whatsappMessage)}`}
            variant="primary"
            class="bg-white text-accent hover:bg-gray-100"
          >
            {lang === 'es' ? 'Envíanos un Mensaje' : 'Message Us'}
          </Button>
        </div>
      </div>

      <div class="mt-12 pt-8 border-t border-white/20">
        <p class="text-lg opacity-90">
          {lang === 'es'
            ? 'Normalmente respondemos en 24 horas'
            : 'We typically respond within 24 hours'
          }
        </p>
      </div>
    </div>
  </div>
</section>
