---
/**
 * Logos Section
 * Showcase client and venue logos
 */
import { useTranslations, type Language } from "../../i18n/utils";

interface Props {
  lang?: Language;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

// Load logos from CMS (dynamically load all MD files)
const logoModules = import.meta.glob("../../data/logos/*.md", { eager: true });
const logoFiles = Object.values(logoModules);
const logos =
  logoFiles.length > 0
    ? logoFiles
        .map((file: any) => file.frontmatter)
        .sort((a: any, b: any) => a.order - b.order)
        .map((item: any) => ({
          name: item.name,
          src: item.logo,
        }))
    : // Fallback to existing logos if no CMS data exists
      [
        { name: "INERCIA", src: "/images/logos/inercia-blanco.png" },
        { name: "INERCIA", src: "/images/logos/inercia-negro.png" },
      ];
---

<section id="logos" class="section-padding">
  <div class="container-custom">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        {t("logos.title")}
      </h2>
      <p class="text-xl text-gray-200">
        {
          lang === "es"
            ? "Estamos orgullosos de haber tocado en lugares y eventos prestigiosos"
            : "We're proud to have performed at prestigious venues and events"
        }
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-4 md:gap-6">
      {
        logos.map((logo) => (
          <div class="flex items-center justify-center p-4 w-[calc(50%-8px)] md:w-[calc(33.333%-16px)] lg:w-[calc(16.666%-20px)] h-[80px] md:h-[100px] lg:h-[120px] bg-white/80 rounded-lg">
            <img
              src={logo.src}
              alt={`${logo.name} logo`}
              class="max-w-full max-h-full object-contain grayscale hover:grayscale-0 transition-all duration-300 opacity-70 hover:opacity-100"
              loading="lazy"
            />
          </div>
        ))
      }
    </div>

    {
      logoFiles.length === 0 && (
        <div class="text-center mt-8">
          <p class="text-gray-300 italic">
            {lang === "es"
              ? "* Añade aquí tus logos reales de clientes/lugares"
              : "* Add your actual client/venue logos here"}
          </p>
        </div>
      )
    }
  </div>
</section>
