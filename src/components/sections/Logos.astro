---
/**
 * Logos Section
 * Showcase client and venue logos
 */
import { useTranslations, type Language } from '../../i18n/utils';

interface Props {
  lang?: Language;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

// Load logos from CMS (dynamically load all JSON files)
const logoModules = import.meta.glob('../../data/logos/*.json', { eager: true });
const logoFiles = Object.values(logoModules);
const logos = logoFiles.length > 0
  ? logoFiles
      .map((file: any) => file.default)
      .sort((a: any, b: any) => a.order - b.order)
      .map((item: any) => ({
        name: item.name,
        src: item.logo
      }))
  : // Fallback to placeholder data if no CMS data exists
    [
      { name: 'Client 1', src: '/images/logos/placeholder-1.png' },
      { name: 'Client 2', src: '/images/logos/placeholder-2.png' },
      { name: 'Client 3', src: '/images/logos/placeholder-3.png' },
      { name: 'Client 4', src: '/images/logos/placeholder-4.png' },
      { name: 'Client 5', src: '/images/logos/placeholder-5.png' },
      { name: 'Client 6', src: '/images/logos/placeholder-6.png' }
    ];
---

<section id="logos" class="section-padding bg-gray-100">
  <div class="container-custom">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        {t('logos.title')}
      </h2>
      <p class="text-xl text-gray-600">
        {lang === 'es'
          ? 'Estamos orgullosos de haber tocado en lugares y eventos prestigiosos'
          : 'We\'re proud to have performed at prestigious venues and events'
        }
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 items-center">
      {logos.map((logo) => (
        <div class="flex items-center justify-center">
          <img
            src={logo.src}
            alt={`${logo.name} logo`}
            class="max-w-full h-16 object-contain grayscale hover:grayscale-0 transition-all duration-300 opacity-70 hover:opacity-100"
            loading="lazy"
            width="200"
            height="80"
          />
        </div>
      ))}
    </div>

    {logoFiles.length === 0 && (
      <div class="text-center mt-8">
        <p class="text-gray-600 italic">
          {lang === 'es'
            ? '* Añade aquí tus logos reales de clientes/lugares'
            : '* Add your actual client/venue logos here'
          }
        </p>
      </div>
    )}
  </div>
</section>
