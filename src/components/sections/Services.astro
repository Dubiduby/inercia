---
/**
 * Services Section
 * Displays three service offerings using accordions
 */
import Accordion from '../ui/Accordion.astro';
import { useTranslations, type Language } from '../../i18n/utils';

interface Props {
  lang?: Language;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

// Load all services dynamically from folder
const allServicesEs = import.meta.glob('../../data/services/es/*.json', { eager: true });
const allServicesEn = import.meta.glob('../../data/services/en/*.json', { eager: true });

const allServices = lang === 'es' ? allServicesEs : allServicesEn;

// Combine and sort services by order
const services = Object.values(allServices)
  .map((module: any) => module.default)
  .sort((a, b) => a.order - b.order)
  .map(service => ({
    title: service.title,
    description: service.description,
    tags: service.tags || [],
    youtubeVideoId: service.youtubeVideoId || '',
    verticalVideo: service.verticalVideo || false,
    layout: service.layout || 'center',
    backgroundImage: service.backgroundImage || ''
  }));

// Layout classes based on service layout setting
const layoutClasses = {
  spread: 'grid grid-cols-1 md:grid-cols-2 gap-6 items-start',
  center: 'flex flex-col md:flex-row gap-10 items-start justify-center',
  right: 'flex flex-col md:flex-row gap-10 items-start justify-end'
};
---

<section id="services" class="section-padding">
  <div class="container-custom">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          {t('services.title')}
        </h2>
        <p class="text-xl text-gray-200">
          {lang === 'es'
            ? 'Música en vivo profesional adaptada a tu evento'
            : 'Professional live music tailored to your event'
          }
        </p>
      </div>

      <div class="space-y-4">
        {services.map((service, index) => (
          <Accordion title={service.title} isOpen={index === 0} backgroundImage={service.backgroundImage}>
            <div class="space-y-6">
              <!-- Description -->
              <div class={`prose prose-sm max-w-none ${service.backgroundImage ? 'text-gray-800' : 'text-gray-700'}`}>
                {service.description.split('\n\n').map((p: string) => (
                  <p>{p}</p>
                ))}
              </div>

              <!-- Tags and Video -->
              <div class={layoutClasses[service.layout as keyof typeof layoutClasses]}>
                <!-- Tags List -->
                <div class="space-y-1">
                  {service.tags.map((tag: string) => (
                    <p class={`font-semibold ${service.backgroundImage ? 'text-gray-800' : 'text-gray-900'}`}>{tag}</p>
                  ))}
                </div>

                <!-- YouTube Video -->
                {service.youtubeVideoId && (
                  <div class={`rounded-lg overflow-hidden shadow-md ${service.verticalVideo ? 'aspect-[9/16] w-full md:w-48 md:ml-32' : 'aspect-video w-full md:w-80'}`}>
                    <iframe
                      src={`https://www.youtube.com/embed/${service.youtubeVideoId}`}
                      title={service.title}
                      class="w-full h-full border-0"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    ></iframe>
                  </div>
                )}
              </div>
            </div>
          </Accordion>
        ))}
      </div>
    </div>
  </div>
</section>
