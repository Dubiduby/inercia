---
/**
 * Services Showcase Section
 * Interactive accordion with video preview that changes on selection
 */
import { useTranslations, type Language } from "../../i18n/utils";
import { extractYouTubeId } from "../../utils/youtube";

interface Props {
  lang?: Language;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

// Load all services dynamically from folder
const allServicesEs = import.meta.glob("../../data/services/es/*.json", {
  eager: true,
});
const allServicesEn = import.meta.glob("../../data/services/en/*.json", {
  eager: true,
});

const allServices = lang === "es" ? allServicesEs : allServicesEn;

// Combine and sort services by order
const services = Object.values(allServices)
  .map((module: any) => module.default)
  .sort((a, b) => a.order - b.order)
  .map((service, index) => ({
    id: `service-${index}`,
    number: String(index + 1).padStart(2, "0"),
    title: service.title,
    subtitle: service.subtitle || "",
    description: service.description,
    tags: service.tags || [],
    youtubeVideoId: extractYouTubeId(service.youtubeVideoId || ""),
    verticalVideo: service.verticalVideo || false,
  }));
---

<section id="services-showcase" class="services-showcase">
  <h2
    class="text-3xl md:text-4xl font-bold text-gray-900 mb-8 md:mb-12 text-center"
  >
    {t("services.title")}
  </h2>
  <div class="services-container" id="services-container">
    <!-- Video Side -->
    <div class="video-side">
      {
        services.map((service, index) => (
          <div
            class={`video-wrapper ${index === 0 ? "active" : ""} ${service.verticalVideo ? "vertical" : ""}`}
            data-video-id={service.id}
            data-vertical={service.verticalVideo ? "true" : "false"}
          >
            {service.verticalVideo ? (
              <div class="iphone-mockup">
                <div class="iphone-frame">
                  <div class="iphone-notch" />
                  <div class="iphone-screen">
                    {service.youtubeVideoId && (
                      <iframe
                        src={`https://www.youtube.com/embed/${service.youtubeVideoId}?rel=0`}
                        title={service.title}
                        class="video-iframe-vertical"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                        loading="lazy"
                      />
                    )}
                  </div>
                </div>
              </div>
            ) : service.youtubeVideoId ? (
              <iframe
                src={`https://www.youtube.com/embed/${service.youtubeVideoId}?rel=0`}
                title={service.title}
                class="video-iframe"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              />
            ) : (
              <div class="video-placeholder">
                <span>Video</span>
              </div>
            )}
          </div>
        ))
      }
    </div>

    <!-- Cards Side -->
    <div class="cards-side">
      {
        services.map((service, index) => (
          <div
            class={`service-card ${index === 0 ? "active" : ""}`}
            data-service-id={service.id}
          >
            <div class="card-header">
              <span class="card-label">{service.title}</span>
              <span class="card-number">{service.number}</span>
            </div>

            <div class="card-content">
              <div class="card-content-inner">
                <h3 class="card-title">{service.subtitle}</h3>

                <p class="card-description">
                  {service.description.replace(/\n/g, " ").slice(0, 200)}
                  {service.description.length > 200 ? "..." : ""}
                </p>

                <a href="#contact" class="card-button">
                  {lang === "es" ? "Más información" : "Learn more"}
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services-showcase {
    padding: 6rem 0;
    min-height: 100vh;
  }

  .services-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  /* Mobile: accordions first, videos second */
  .video-side {
    order: 2;
  }

  .cards-side {
    order: 1;
  }

  @media (min-width: 1024px) {
    .services-container {
      grid-template-columns: 5fr 4fr;
      gap: 2rem;
      padding: 0 2rem;
    }

    /* Desktop: video on left, cards on right */
    .video-side {
      order: 1;
    }

    .cards-side {
      order: 2;
    }
  }

  /* Video Side */
  .video-side {
    position: relative;
    aspect-ratio: 16/9;
    border-radius: 0.5rem;
    overflow: hidden;
    background: #1a1a1a;
    max-height: 250px;
  }

  .video-side:has(.video-wrapper.vertical.active) {
    background: transparent;
    aspect-ratio: 9/16;
    max-height: 400px;
  }

  @media (min-width: 1024px) {
    .video-side {
      position: sticky;
      top: 6rem;
      height: auto;
      max-height: 70vh;
      aspect-ratio: 16/10;
    }

    .video-side:has(.video-wrapper.vertical.active) {
      max-height: none;
      height: 85vh;
      aspect-ratio: auto;
      display: flex;
      justify-content: center;
      align-items: center;
      overflow: visible;
    }
  }

  .video-wrapper {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .video-wrapper.active {
    opacity: 1;
    pointer-events: auto;
  }

  .video-iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* iPhone Mockup */
  .video-wrapper.vertical {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
  }

  @media (min-width: 1024px) {
    .video-wrapper.vertical.active {
      position: relative;
      inset: auto;
      height: 100%;
    }
  }

  .iphone-mockup {
    height: 100%;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 0.5rem 0.5rem 0.5rem 0.5rem;
  }

  .iphone-frame {
    position: relative;
    background: #1a1a1a;
    border-radius: 3rem;
    padding: 0.5rem;
    box-shadow:
      0 0 0 2px #333,
      0 20px 50px rgba(0, 0, 0, 0.4);
    height: 100%;
    max-height: 60vh;
    aspect-ratio: 9/19.5;
  }

  .iphone-notch {
    position: absolute;
    top: 0.8rem;
    left: 50%;
    transform: translateX(-50%);
    width: 30%;
    height: 1.5rem;
    background: #1a1a1a;
    border-radius: 1rem;
    z-index: 10;
  }

  .iphone-screen {
    width: 100%;
    height: 100%;
    background: #000;
    border-radius: 2.5rem;
    overflow: hidden;
  }

  .video-iframe-vertical {
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* Layout change for vertical video */
  @media (min-width: 1024px) {
    .services-container.vertical-active {
      grid-template-columns: 2fr 3fr;
      align-items: start;
    }
  }

  .video-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #2a2a2a, #1a1a1a);
    color: #666;
    font-size: 1.5rem;
  }

  /* Cards Side */
  .cards-side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .service-card {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    border-radius: 0.5rem;
    padding: 1.5rem 2rem;
    cursor: pointer;
    transition: all 0.4s ease;
    overflow: hidden;
  }

  .service-card:hover {
    background: rgba(255, 255, 255, 0.9);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-label {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #000;
  }

  .card-number {
    font-size: 1rem;
    font-weight: 600;
    color: #333;
  }

  .card-content {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      margin-top 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-content-inner {
    overflow: hidden;
  }

  .service-card.active .card-content {
    grid-template-rows: 1fr;
    opacity: 1;
    margin-top: 0.75rem;
  }

  .card-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #000;
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .card-title {
      font-size: 1.9rem;
    }
  }

  .card-description {
    font-size: 1rem;
    line-height: 1.6;
    color: #333;
    margin-bottom: 1.5rem;
  }

  .card-button {
    display: inline-block;
    padding: 0.6rem 1.2rem;
    background: #1a1a1a;
    color: #fff;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition:
      background 0.3s ease,
      transform 0.2s ease;
  }

  .card-button:hover {
    background: #333;
    transform: translateY(-2px);
  }
</style>

<script>
  function initServicesShowcase() {
    const container = document.getElementById("services-container");
    const cards = document.querySelectorAll(".service-card");
    const videos = document.querySelectorAll(".video-wrapper");

    cards.forEach((card) => {
      card.addEventListener("click", () => {
        const serviceId = card.getAttribute("data-service-id");

        // Update active card
        cards.forEach((c) => c.classList.remove("active"));
        card.classList.add("active");

        // Update active video and check if vertical
        let isVertical = false;
        videos.forEach((v) => {
          if (v.getAttribute("data-video-id") === serviceId) {
            v.classList.add("active");
            isVertical = v.getAttribute("data-vertical") === "true";
          } else {
            v.classList.remove("active");
          }
        });

        // Toggle layout based on video orientation
        if (container) {
          if (isVertical) {
            container.classList.add("vertical-active");
          } else {
            container.classList.remove("vertical-active");
          }
        }
      });
    });
  }

  // Initialize
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initServicesShowcase);
  } else {
    initServicesShowcase();
  }

  document.addEventListener("astro:page-load", initServicesShowcase);
</script>
