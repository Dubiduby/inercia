---
/**
 * Navbar Component
 * Sticky navigation with mobile hamburger menu, smooth scroll, and language selector
 */
import { useTranslations, type Language } from "../../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Determine the alternate language URL
const currentPath = Astro.url.pathname;
const isEnglish = lang === "en";
const alternateLang = isEnglish ? "es" : "en";
const alternatePath = isEnglish
  ? currentPath.replace("/en/", "/").replace("/en", "/")
  : `/en${currentPath}`;
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 ease-in-out">
  <div class="container-custom">
    <div class="flex items-center justify-between py-4">
      <!-- Logo -->
      <a
        href={lang === "es" ? "/" : "/en/"}
        class="relative flex items-center hover:opacity-80 transition-opacity h-10 w-24"
      >
        <img
          src="/images/logos/inercia-blanco.png"
          alt="Inercia"
          class="logo-white h-10 w-auto"
        />
        <img
          src="/images/logos/inercia-negro.png"
          alt="Inercia"
          class="logo-dark h-10 w-auto"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        <a href="#about" class="nav-link">{t("nav.about")}</a>
        <a href="#services" class="nav-link">{t("nav.services")}</a>
        <a href="#gallery" class="nav-link">{t("nav.gallery")}</a>
        <a href="#contact" class="nav-link">{t("nav.contact")}</a>

        <!-- Language Selector (Desktop) -->
        <a
          href={alternatePath}
          class="lang-selector px-3 py-1.5 text-sm font-semibold rounded-lg transition-colors"
          aria-label={`Switch to ${alternateLang === "en" ? "English" : "Español"}`}
        >
          {alternateLang.toUpperCase()}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden p-2 rounded-lg transition-colors"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            class="hamburger"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
          <path
            class="close hidden"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden pb-4">
      <div class="flex flex-col space-y-4 items-center">
        <a href="#about" class="nav-link">{t("nav.about")}</a>
        <a href="#services" class="nav-link">{t("nav.services")}</a>
        <a href="#gallery" class="nav-link">{t("nav.gallery")}</a>
        <a href="#contact" class="nav-link">{t("nav.contact")}</a>

        <!-- Language Selector (Mobile) -->
        <a
          href={alternatePath}
          class="px-4 py-2 text-center text-sm font-semibold rounded-lg bg-[#F0EBE3] text-[#2F261B] hover:bg-[#483A28] hover:text-white transition-colors"
          aria-label={`Switch to ${alternateLang === "en" ? "English" : "Español"}`}
        >
          {alternateLang === "en" ? "English" : "Español"}
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  /* Estado inicial: transparente con texto blanco */
  .nav-link {
    @apply text-white font-medium;
    transition: color 500ms ease-in-out, transform 300ms ease-in-out;
  }

  .nav-link:hover {
    @apply text-gray-200;
  }

  /* Estado con scroll: fondo sólido */
  .navbar-scrolled {
    background-color: #F9F6F1;
    @apply backdrop-blur-sm shadow-md;
  }

  .navbar-scrolled .nav-link {
    color: #483A28;
  }

  .navbar-scrolled .nav-link:hover {
    color: #3d3325;
    transform: translateY(-2px);
  }

  /* Logos con transición de opacidad */
  .logo-white,
  .logo-dark {
    transition: opacity 500ms ease-in-out;
    position: absolute;
  }

  .logo-white {
    opacity: 1;
  }

  .logo-dark {
    opacity: 0;
  }

  .navbar-scrolled .logo-white {
    opacity: 0;
  }

  .navbar-scrolled .logo-dark {
    opacity: 1;
  }

  /* Botón mobile */
  #mobile-menu-button {
    @apply text-white;
    transition: all 500ms ease-in-out;
  }

  #mobile-menu-button:hover {
    @apply bg-white/20;
  }

  .navbar-scrolled #mobile-menu-button {
    @apply text-gray-700;
  }

  .navbar-scrolled #mobile-menu-button:hover {
    @apply bg-gray-100;
  }

  /* Selector de idioma */
  .lang-selector {
    @apply bg-white/20 text-white hover:bg-white hover:text-gray-700;
    transition: all 500ms ease-in-out;
  }

  .navbar-scrolled .lang-selector {
    @apply hover:text-white;
    background-color: #F0EBE3;
    color: #2F261B;
  }

  .navbar-scrolled .lang-selector:hover {
    background-color: #483A28;
  }

  /* Menú mobile — dropdown absoluto, no estira el nav */
  #mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: #F9F6F1;
    @apply backdrop-blur-sm shadow-md;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    visibility: hidden;
    transition: max-height 250ms ease-in-out, opacity 250ms ease-in-out, visibility 250ms ease-in-out;
  }

  #mobile-menu.is-open {
    max-height: 300px;
    opacity: 1;
    visibility: visible;
  }

  #mobile-menu .nav-link {
    color: #483A28;
  }

  #mobile-menu .nav-link:hover {
    color: #3d3325;
    transform: translateY(-2px);
  }
</style>

<script>
  // Navbar scroll behavior
  const navbar = document.getElementById("navbar");
  const scrollThreshold = 50;
  let mobileMenuOpen = false;

  function handleScroll() {
    if (mobileMenuOpen) {
      // Keep scrolled state when mobile menu is open
      navbar?.classList.add("navbar-scrolled");
      return;
    }

    if (window.scrollY > scrollThreshold) {
      navbar?.classList.add("navbar-scrolled");
    } else {
      navbar?.classList.remove("navbar-scrolled");
    }
  }

  window.addEventListener("scroll", handleScroll);
  handleScroll(); // Run on load in case page is already scrolled

  // Mobile menu toggle
  const menuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const hamburgerIcon = menuButton?.querySelector(".hamburger");
  const closeIcon = menuButton?.querySelector(".close");

  menuButton?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.contains("is-open");

    if (!isOpen) {
      mobileMenu?.classList.add("is-open");
      hamburgerIcon?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
      menuButton?.setAttribute("aria-expanded", "true");
      mobileMenuOpen = true;
      navbar?.classList.add("navbar-scrolled"); // Force scrolled state
    } else {
      mobileMenu?.classList.remove("is-open");
      hamburgerIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      menuButton?.setAttribute("aria-expanded", "false");
      mobileMenuOpen = false;
      handleScroll(); // Restore correct state based on scroll position
    }
  });

  // Close mobile menu when clicking a link
  const mobileLinks = mobileMenu?.querySelectorAll("a");
  mobileLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.remove("is-open");
      hamburgerIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      menuButton?.setAttribute("aria-expanded", "false");
      mobileMenuOpen = false;
      handleScroll(); // Restore correct state based on scroll position
    });
  });

  // Smooth scroll for all anchor links
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", (e) => {
      e.preventDefault();
      const href = anchor.getAttribute("href");
      if (href) {
        const target = document.querySelector(href);
        target?.scrollIntoView({
          behavior: "smooth",
          block: "start",
        });
      }
    });
  });
</script>
